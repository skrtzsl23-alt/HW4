   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "matrix",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Матрица переходов (из задания 5)\n",
    "transition_matrix = np.array([\n",
    "    [0.32062714, 0.23231163, 0.25632212, 0.19073911],\n",
    "    [0.21009642, 0.28473236, 0.27851769, 0.22665352],\n",
    "    [0.27058941, 0.21188479, 0.28881877, 0.22870704],\n",
    "    [0.33945501, 0.30711288, 0.07056934, 0.28286277]\n",
    "])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "7b38d0d1-5429-428a-a391-918be85633e0",
   "metadata": {},
   "outputs": [],
   "source": [
    "P = transition_matrix"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "1b8e1eb9-5aef-490c-9cea-29e847c43a38",
   "metadata": {},
   "outputs": [],
   "source": [
    "P_prev = P.copy()\n",
    "P_k = P.copy()  \n",
    "norm_diff = []\n",
    "for k in range(2, 1001):\n",
    "    P_k = P_k @ P  \n",
    "    diff = np.linalg.norm(P_k - P_prev, ord='fro')\n",
    "    norm_diff.append(diff)\n",
    "    P_prev = P_k.copy()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "e5c75667-0841-43dd-8364-7b10e7fdbd25",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",

</output>
    }
   ],
   "source": [
    "plt.figure(figsize=(10,5))\n",
    "plt.plot(range(2, 1001), norm_diff)\n",
    "plt.xlabel('k (степень матрицы)')\n",
    "plt.ylabel('||P^k - P^(k-1)||_F')\n",
    "plt.title('Сходимость P^k к стационарной матрице')\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "bf1cfe7d-20c1-4823-8901-90929886c3a7",
   "metadata": {},
