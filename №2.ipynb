{
 "cells": [
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "setup",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Transcription Factor Binding Sites Search in Genome\n",
    "# Homework 4 - Task 2: PWM/PSSM scanning\n",
    "# Author: skrtzsl23-alt\n",
    "\n",
    "from Bio import motifs\n",
    "from Bio.Seq import Seq\n",
    "from Bio import SeqIO\n",
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "input_sequences",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Input binding sites (known TF binding sequences)\n",
    "binding_sites = [\n",
    "    \"GAGGTAAAC\",\n",
    "    \"TCCGTAAGC\",\n",
    "    \"CAGGTTGGA\",\n",
    "    \"ACAGTCAGC\",\n",
    "    \"TAGGTCAGC\",\n",
    "    \"CAGGTCAGC\",\n",
    "    \"CAGGTCGAT\",\n",
    "    \"CAGGTCAGC\",\n",
    "    \"CAGGTCAGC\",\n",
    "    \"CAGGTTGGC\"\n",
    "]\n",
    "\n",
    "# Convert to Seq objects as required by Bio.motifs\n",
    "seq_objects = [Seq(seq) for seq in binding_sites]\n",
    "\n",
    "# Create motif from sequences\n",
    "motif = motifs.create(seq_objects)\n",
    "\n",
    "# Extract Position Weight Matrix (PWM) and Position-Specific Scoring Matrix (PSSM)\n",
    "position_weight_matrix = motif.pwm\n",
    "pssm_matrix = motif.pssm"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "view_pwm",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "{'A': (0.1, 0.8, 0.1, 0.0, 0.0, 0.2, 0.7, 0.2, 0.1),\n",
       " 'C': (0.6, 0.2, 0.1, 0.0, 0.0, 0.6, 0.0, 0.0, 0.8),\n",
       " 'G': (0.1, 0.0, 0.8, 1.0, 0.0, 0.0, 0.3, 0.8, 0.0),\n",
       " 'T': (0.2, 0.0, 0.0, 0.0, 1.0, 0.2, 0.0, 0.0, 0.1)}"
      ]
     },
     "execution_count": 27,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "position_weight_matrix"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "load_genome",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load genome from FASTA file (first 100,000 bases for analysis)\n",
    "fasta_records = SeqIO.parse(\"chr1.fa\", \"fasta\")\n",
    "first_record = next(fasta_records)\n",
    "full_genome = first_record.seq\n",
    "genome_region = full_genome[:100000]\n",
    "\n",
    "print(f\"Genome region length: {len(genome_region)} bp\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "scan_forward",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Scan forward strand\n",
    "forward_hits = []\n",
    "score_threshold = 5.0\n",
    "\n",
    "for position, score in pssm_matrix.search(genome_region, threshold=score_threshold):\n",
    "    forward_hits.append((position, \"+\", score))\n",
    "\n",
    "print(f\"Found {len(forward_hits)} hits on forward strand (threshold >= {score_threshold})\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "scan_reverse",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Scan reverse complement strand\n",
    "reverse_genome = genome_region.reverse_complement()\n",
    "reverse_hits = []\n",
    "\n",
    "for position, score in pssm_matrix.search(reverse_genome, threshold=score_threshold):\n",
    "    reverse_hits.append((position, \"-\", score))\n",
    "\n",
    "print(f\"Found {len(reverse_hits)} hits on reverse strand (threshold >= {score_threshold})\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "combine_results",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Combine all hits\n",
    "all_hits = forward_hits + reverse_hits\n",
    "print(f\"\\n=== TOTAL HITS: {len(all_hits)} ===\")"
   ]
  },
