   "outputs": [],
   "source": [
    "import numpy as np\n",
    "from Bio import motifs\n",
    "from Bio.Seq import Seq\n",
    "from Bio import SeqIO\n",
    "import matplotlib.pyplot as plt\n",
    "from Bio.motifs.matrix import PositionSpecificScoringMatrix"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 77,
   "id": "af54c5ef-badc-4254-8ed1-0e9b2027a065",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Input binding sites\n",
    "binding_sites = [\n",
    "    \"GAGGTAAAC\",\n",
    "    \"TCCGTAAGC\",\n",
    "    \"CAGGTTGGA\",\n",
    "    \"ACAGTCAGC\",\n",
    "    \"TAGGTCAGC\",\n",
    "    \"CAGGTCAGC\",\n",
    "    \"CAGGTCGAT\",\n",
    "    \"CAGGTCAGC\",\n",
    "    \"CAGGTCAGC\",\n",
    "    \"CAGGTTGGC\"\n",
    "]\n",
    "\n",
    "seq_objects = [Seq(s) for s in binding_sites]\n",
    "\n",
    "motif = motifs.create(seq_objects)\n",
    "\n",
    "position_weight_matrix = motif.pwm"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 78,
   "id": "3af83e82-5313-4b2a-a045-ac6cbd6bfaf4",
   "metadata": {},
   "outputs": [],
   "source": [
    "nucleotide_alphabet = ['A', 'C', 'G', 'T']\n",
    "nucleotide_to_index = {n: i for i, n in enumerate(nucleotide_alphabet)}\n",
    "\n",
    "background_probs = [0.295, 0.295, 0.205, 0.205]\n",
    "\n",
    "def generate_random_sequence(length=9):\n",
    "    \"\"\"Generate random DNA sequence based on background frequencies.\"\"\"\n",
    "    return \"\".join(np.random.choice(nucleotide_alphabet, p=background_probs, size=length))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 79,
   "id": "d678ab50-66c9-407d-bcdd-3ee252c4a1ef",
   "metadata": {},
   "outputs": [],
   "source": [
    "def compute_sequence_score(sequence, pssm):\n",
    "    \"\"\"Calculate PSSM score for a given sequence.\"\"\"\n",
    "    return sum(pssm[n][i] for i, n in enumerate(sequence))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 81,
   "id": "3ce46ef5-c8e5-477f-86c1-3b282e4b7a88",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate random scores distribution (100,000 random sequences)\n",
    "random_scores = np.array([compute_sequence_score(generate_random_sequence(9), position_weight_matrix) for _ in range(100000)])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 82,
   "id": "538f460c-bac3-4df9-9656-cb4a6e1809dc",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "
     "output_type": "display_data"
    }
   ],
   "source": [
    "plt.figure()\n",
    "plt.hist(random_scores, bins=50)\n",
    "plt.xlabel(\"PWM score\")\n",
    "plt.ylabel(\"Frequency\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 85,
   "id": "6a16118f-9829-4d3f-aca5-1117b7fb6f1a",
   "metadata": {},
   "outputs": [],
   "source": [
    "def compute_pvalue(score):\n",
    "    return np.mean(random_scores >= score)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 86,
   "id": "085e3a82-5464-49e2-81ef-18c3b88813ac",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "6.204504504504505\n"
     ]
    }
   ],
   "source": [
    "threshold_value = None\n",
    "for t in np.linspace(random_scores.min(), random_scores.max(), 1000):\n",
    "    if compute_pvalue(t) <= 1e-4:\n",
    "        threshold_value = t\n",
    "        break\n",
    "print(threshold_value)"
   ]
  },
  {
